name: CI - Build, Test, Push to ECR, Update k8s Repo

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

env:
  SERVICE_NAME: frontend
  AWS_REGION: ap-northeast-1
  ECR_REGISTRY: ${{ secrets.AWS_ACCOUNT_ID }}.dkr.ecr.ap-northeast-1.amazonaws.com

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
      - run: npm ci
      - run: npm run lint

  test:
    runs-on: ubuntu-latest
    needs: [lint]
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
      - run: npm ci
      - run: npm test -- --coverage
      - uses: actions/upload-artifact@v4
        with:
          name: coverage
          path: coverage/

  sonar:
    runs-on: ubuntu-latest
    needs: [test]
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: actions/download-artifact@v4
        with:
          name: coverage
          path: coverage/
      - uses: SonarSource/sonarcloud-github-action@v2
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          SONAR_TOKEN: ${{ secrets.SONAR_TOKEN }}

  build-and-push:
    needs: [sonar]
    runs-on: ubuntu-latest
    if: github.event_name == 'push' && github.ref == 'refs/heads/main'
    permissions:
      contents: read
      id-token: write
    steps:
      - uses: actions/checkout@v4

      - name: Configure AWS credentials
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id: ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-region: ${{ env.AWS_REGION }}

      - name: Login to ECR
        run: |
          aws ecr get-login-password --region ${{ env.AWS_REGION }} | \
            docker login --username AWS --password-stdin ${{ env.ECR_REGISTRY }}

      - name: Build Docker image
        run: |
          docker build -t ${{ env.ECR_REGISTRY }}/${{ env.SERVICE_NAME }}:${{ github.sha }} .
          docker tag ${{ env.ECR_REGISTRY }}/${{ env.SERVICE_NAME }}:${{ github.sha }} \
                     ${{ env.ECR_REGISTRY }}/${{ env.SERVICE_NAME }}:latest

      - name: Push to ECR
        run: |
          docker push ${{ env.ECR_REGISTRY }}/${{ env.SERVICE_NAME }}:${{ github.sha }}
          docker push ${{ env.ECR_REGISTRY }}/${{ env.SERVICE_NAME }}:latest

      - name: Update image tag in k8s repo
        uses: actions/github-script@v7
        with:
          github-token: ${{ secrets.GH_TOKEN }}
          script: |
            const owner = 'proops2026-helpdesk'
            const repo = 'k8s'
            const path = `helm/values/${{ env.SERVICE_NAME }}.yaml`

            // Get current file — SHA is required for atomic update
            const { data: file } = await github.rest.repos.getContent({ owner, repo, path })

            // Replace only the `tag:` line (preserves all other values)
            const content = Buffer.from(file.content, 'base64').toString()
            const updated = content.replace(/^(\s*tag:\s*).*$/m, `$1${{ github.sha }}`)

            // Single atomic API call — no clone, no race condition
            await github.rest.repos.createOrUpdateFileContents({
              owner,
              repo,
              path,
              message: `ci: bump ${{ env.SERVICE_NAME }} to ${{ github.sha }}`,
              content: Buffer.from(updated).toString('base64'),
              sha: file.sha,
            })
            console.log(`✅ Updated ${path} → ${{ github.sha }}`)

      - name: Summary
        run: |
          echo "✅ Image pushed: ${{ env.ECR_REGISTRY }}/${{ env.SERVICE_NAME }}:${{ github.sha }}"
          echo "✅ k8s repo updated: proops2026-helpdesk/k8s helm/values/${{ env.SERVICE_NAME }}.yaml"
